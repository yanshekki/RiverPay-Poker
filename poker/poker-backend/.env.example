PORT=3001
NODE_ENV=development

# Blockchain
PRIVATE_KEY=0x_your_backend_private_key_here
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
USDT_ADDRESS=0x9702230A8Ea53601f5cD2dc00fDBc13d4dF4A8c7

# CORS
CORS_ORIGIN=*

# Database
DATABASE_URL=mysql://user:password@localhost:3306/poker_db
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your_jwt_secret_here_change_me
JWT_EXPIRES_IN=7d

# Platform
PLATFORM_WALLET=0x_your_commission_wallet_address
PLATFORM_FEE_PERCENT=10
